# Path to your application log file (absolute path)
LOG_PATH=/var/log/myapp/app.log

# Name used to tag logs in Elasticsearch (index: logs-<APP_NAME>-YYYY.MM.dd)
APP_NAME=myapp

# Log format: json | text
# json = each line parsed as JSON, all keys become searchable Kibana fields
# text = entire line stored as `message` field, use full-text search in Kibana
LOG_FORMAT=json
